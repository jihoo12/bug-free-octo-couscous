-- 1. Define the equivalence (Identity on U0)
def idEquiv : Equiv U0 U0 = mkEquiv U0 U0 (λx. x) (λx. x) (λa. ⟨i⟩ a) (λb. (⟨i⟩ b))

-- 2. Turn it into a path
def uaPath : Path U1 U0 U0 = ua idEquiv

-- 3. Transport 𝕀 (which is in U0) along the path. 
-- This works because the path is Path U1 U0 U0.
def result : U0 = transport uaPath 𝕀

-- 4. Verify the result
check finalTest : U0 = result